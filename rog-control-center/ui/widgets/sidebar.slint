import { Palette, HorizontalBox, VerticalBox } from "std-widgets.slint";
import { Theme } from "../globals.slint";

component SideBarItem inherits Rectangle {
    in property <bool> selected;
    in property <bool> has-focus;
    in-out property <string> text <=> label.text;
    callback clicked <=> touch.clicked;
    min-height: self.visible ? 38px : 0px;
    border-radius: Theme.border-radius-sm;

    background: selected ? Theme.accent-glow : (touch.has-hover ? Theme.surface-hover : transparent);

    animate background { duration: 180ms; easing: ease-in-out; }

    // Active selection indicator bar on the left
    indicator := Rectangle {
        x: 2px;
        y: (parent.height - self.height) / 2;
        width: selected ? 4px : 0px;
        height: selected ? 22px : 0px;
        border-radius: 2px;
        background: Theme.accent;
        drop-shadow-color: Theme.accent-glow;
        drop-shadow-blur: selected ? 8px : 0px;

        animate width, height, opacity { duration: 200ms; easing: ease-out; }
    }

    l := HorizontalBox {
        x: 12px;
        y: (parent.height - self.height) / 2;
        spacing: 0px;
        label := Text {
            color: root.selected ? Theme.text-primary : (touch.has-hover ? Theme.text-primary : Theme.text-secondary);
            vertical-alignment: center;
            font-size: 13px;
            font-weight: root.selected ? 700 : 500;

            animate color { duration: 180ms; easing: ease-in-out; }
        }
    }

    touch := TouchArea {
        width: 100%;
        height: 100%;
    }
}

export component SideBar inherits Rectangle {
    in property <[string]> model: [];
    in property <[bool]> available: [];
    in property <bool> is_tuf: false;
    out property <int> current-item: 0;
    out property <int> current-focused: fs.has-focus ? fs.focused-tab : -1;

    // The currently focused tab
    width: 180px;
    forward-focus: fs;
    accessible-role: tab;
    accessible-delegate-focus: root.current-focused >= 0 ? root.current-focused : root.current-item;
    Rectangle {
        background: Theme.surface;
        fs := FocusScope {
            key-pressed(event) => {
                if (event.text == "\n") {
                    root.current-item = root.current-focused;
                    return accept;
                }
                if (event.text == Key.UpArrow) {
                    self.focused-tab = Math.max(self.focused-tab - 1,  0);
                    return accept;
                }
                if (event.text == Key.DownArrow) {
                    self.focused-tab = Math.min(self.focused-tab + 1, root.model.length - 1);
                    return accept;
                }
                return reject;
            }
            key-released(event) => {
                if (event.text == " ") {
                    root.current-item = root.current-focused;
                    return accept;
                }
                return reject;
            }
            property <int> focused-tab: 0;
            x: 0;
            width: 0;
            // Do not react on clicks
        }
    }

    VerticalBox {
        spacing: 6px;
        padding-left: 6px;
        padding-right: 6px;
        padding-top: 8px;
        padding-bottom: 8px;
        alignment: start;

        Image {
            height: 90px;
            // TODO: change if TUF on the logo in the menu on the main page
            // If running on a TUF model, replace the ROG red with TUF orange
            // (add data/tuf-control-center.png and switch here when available)
            source: @image-url("../../data/rog-control-center.png");
            horizontal-alignment: center;
            image-fit: contain;
        }

        Rectangle {
            height: 1px;
            background: Theme.card-border;
        }

        navigation := VerticalLayout {
            spacing: 3px;
            alignment: start;
            vertical-stretch: 0;
            for item[index] in root.model: SideBarItem {
                visible: root.available[index];
                clicked => {
                    root.current-item = index;
                }
                has-focus: index == root.current-focused;
                text: item;
                selected: index == root.current-item;
            }
        }

        VerticalLayout {
            bottom := VerticalBox {
                padding-left: 0px;
                padding-top: 0px;
                padding-bottom: 0px;
                @children
            }
        }
    }
}
